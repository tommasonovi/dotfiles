term = xterm-256color
command = /bin/zsh

# ── Font ─────────────────────────────────────────────────────
font-family = JetBrains Mono
font-size = 14

# ── Window / tabs ────────────────────────────────────────────
window-padding-x = 4
window-padding-y = 4
macos-titlebar-style = tabs
window-colorspace = display-p3

# ── Cmd+Arrow → beginning/end of line (works inside tmux) ───
keybind = super+left=text:\x1b[H
keybind = super+right=text:\x1b[F
