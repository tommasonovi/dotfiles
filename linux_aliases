alias pbcopy='xclip -selection clipboard'
alias pbpaste='xclip -selection clipboard -o'

function start_devcontainer() {
  local name="${1:-gpu}"
  local config
  config=$(find .devcontainer -path "*${name}*" -name "devcontainer.json" | head -1)
  if [ -z "$config" ]; then
    echo "No devcontainer.json found${name:+ matching '$name'}."
    echo "Available configs:"
    find .devcontainer -name "devcontainer.json" 2>/dev/null | sed 's|.devcontainer/||;s|/devcontainer.json||' | sed 's|^|  |'
    return 1
  fi
  echo "Starting devcontainer with config: $config"
  devcontainer up --config "$config" --workspace-folder .
}

function connect_devcontainer() {
  local name="${1:-}"
  local container
  if [ -n "$name" ]; then
    container=$(docker ps --filter label=devcontainer.local_folder --format "{{.Names}}" | grep -i "$name" | head -1)
  else
    container=$(docker ps --filter label=devcontainer.local_folder --format "{{.Names}}" | head -1)
  fi
  if [ -z "$container" ]; then
    echo "No devcontainer found${name:+ matching '$name'}."
    echo "Running devcontainers:"
    docker ps --filter label=devcontainer.local_folder --format "  {{.Names}}" 2>/dev/null
    return 1
  fi
  echo "Connecting to: $container"
  docker exec -it "$container" bash -l
}
