[color]
    ui = true

[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = red bold 52
    newNormal = green bold
    newHighlight = green bold 22

[color "diff"]
    meta = 11
    frag = magenta bold
    func = 146 bold
    commit = yellow bold
    old = red bold
    new = green bold
    whitespace = red reverse

[core]
    excludesfile = ~/.gitignore_global

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f

[alias]
    aa = add --all
    pl = pull
    ps = push
    b = branch -vv
    bd = branch -d
    bD = branch -D
    br = branch
    ci = commit
    cim = commit -m
    cima = commit -am
    co = checkout
    cp = cherry-pick -x
    d = diff -w
    mom = fetch origin && merge origin/main
    nb = checkout -b
    oups = commit --amend --no-edit
    r = remote -v
    rh = reset --hard
    st = status -sb
    yeet = "!git push --set-upstream origin $(git symbolic-ref --short HEAD)"
    unstage = reset HEAD
    uncommit = reset --soft HEAD^
    pushfl = push --force-with-lease
    subup = submodule update --recursive
    lg = log --graph --date=relative --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%an %ad)%Creset' -300
    lga = log --graph --date=relative --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%an %ad)%Creset' -300 --all
    nuke = clean -fdx
    nukefile = clean -f
    nukelist = clean -fdxn
    nukefilelist = clean -fn
    cp-pr = "!f() { \
        current_branch=$(git rev-parse --abbrev-ref HEAD) && \
        base_branch=${2:-origin/dev} && \
        fork_point=$(git merge-base $base_branch $1) && \
        git checkout -b temp-branch $fork_point && \
        git cherry-pick $(fork_point)..$(git rev-parse $1) && \
        git reset --soft $fork_point && \
        git commit -m \"Squashed commit of the following from branch $1\" && \
        git checkout $current_branch && \
        git cherry-pick $(git rev-parse temp-branch) && \
        git branch -D temp-branch; \
        }; f"
