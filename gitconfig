[color]
    ui = true

[core]
    excludesfile = ~/.gitignore_global
    pager = delta
    editor = nvim

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    dark = true
    syntax-theme = gruvbox-dark
    minus-style = "red bold"
    minus-emph-style = "red bold 52"
    plus-style = "green bold"
    plus-emph-style = "green bold 22"
    line-numbers-minus-style = "red bold"
    line-numbers-plus-style = "green bold"
    hunk-header-decoration-style = "cyan box"

[merge]
    conflictstyle = diff3
    tool = vimdiff
[mergetool]
    keepBackup = false

[pager]
    diff = less

[diff]
    colorMoved = default

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f

[alias]
    aa = add --all
    pl = pull
    ps = push
    b = branch -vv
    bd = branch -d
    bD = branch -D
    ci = commit
    cim = commit -m
    cima = commit -am
    co = checkout
    cp = checkout -p
    d = "!f() { git diff --name-only \"$@\" | fzf --reverse --ansi --color='pointer:red,prompt:red' --header='Changed files' --bind 'ctrl-f:preview-page-down,ctrl-b:preview-page-up' --preview \"GIT_PAGER=cat git diff --color=always $@ -- {1} | delta --side-by-side --width=\\$FZF_PREVIEW_COLUMNS\" --preview-window=down:80% ; }; f"
    delta = -c pager.diff=delta diff
    ap = add -p
    rp = restore -p
    mom = fetch origin && merge origin/main
    nb = checkout -b
    oups = commit --amend --no-edit
    r = remote -v
    rh = reset --hard
    st = status -sb
    yeet = "!git push --set-upstream origin $(git symbolic-ref --short HEAD)"
    unstage = reset HEAD
    uncommit = reset --soft HEAD^
    pushfl = push --force-with-lease
    subup = submodule update --recursive
    lg = log --graph --date=relative --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%an %ad)%Creset' -300
    lga = log --graph --date=relative --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%an %ad)%Creset' -300 --all
    nukelist = clean -fdn
    nuke = clean -fd
    br = branch --sort=-committerdate --format='%(if)%(HEAD)%(then)%(color:green bold)* %(refname:short)%(color:reset)%(else)  %(color:red bold)%(refname:short)%(color:reset)%(end) %(color:dim)%(committerdate:relative) %(subject)%(color:reset)'
    sw = "!git branch --sort=-committerdate --color --format='%(if)%(HEAD)%(then)%(color:green bold)%(refname:short)%(color:reset)%(else)%(color:red bold)%(refname:short)%(color:reset)%(end) %(color:dim)%(committerdate:relative) %(subject)%(color:reset)' | fzf --reverse --ansi --color='pointer:cyan,prompt:red,fg+:cyan:bold,bg+:#1e3a5f' --header='Switch branch' --preview 'git log --oneline --color -20 {1}' | awk '{print $1}' | xargs git switch"
    brd = "!git branch --sort=-committerdate --color --format='%(if)%(HEAD)%(then)%(color:green bold)%(refname:short)%(color:reset)%(else)%(color:red bold)%(refname:short)%(color:reset)%(end) %(color:dim)%(committerdate:relative) %(subject)%(color:reset)' | fzf --reverse --ansi --multi --color='pointer:cyan,prompt:red,fg+:cyan:bold,bg+:#1e3a5f' --header='Delete branches (TAB to multi-select)' --preview 'git log --oneline --color -20 {1}' | awk '{print $1}' | xargs git branch -d"
